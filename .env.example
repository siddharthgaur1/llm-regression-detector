# Copy to .env and fill in.

# Required. Read implicitly by the OpenAI SDK for both the classifier under
# test and the LLM-as-judge scorer. The eval run fails without it.
OPENAI_API_KEY=sk-...

# Optional. Incoming webhook used by `--slack` to post regression alerts.
# If unset, alerting no-ops with a warning rather than failing the run.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Note: classifier and judge models are CLI flags, not env vars:
#   python -m src.runner --prompt-version v2 --classifier-model gpt-4o-mini --judge-model gpt-4o
