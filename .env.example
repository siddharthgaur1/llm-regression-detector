# Copy to .env and fill in.

# Required to RUN AN EVAL (the dashboard needs no key). Read by the OpenAI SDK for
# both the classifier under test and the LLM-as-judge scorer.
OPENAI_API_KEY=sk-...

# Optional OpenAI-compatible base URL. Empty = OpenAI. Set to run the eval free:
#   Groq:   https://api.groq.com/openai/v1
#   Ollama: http://localhost:11434/v1
OPENAI_BASE_URL=

# Optional. Incoming webhook used by `--slack` to post regression alerts.
# If unset, alerting no-ops with a warning rather than failing the run.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Note: classifier and judge models are CLI flags, not env vars:
#   python -m src.runner --prompt-version v2 --classifier-model gpt-4o-mini --judge-model gpt-4o
